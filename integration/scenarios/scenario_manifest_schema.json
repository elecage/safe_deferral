{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/elecage/safe_deferral/integration/scenarios/scenario_manifest_schema.json",
  "title": "safe_deferral scenario manifest schema",
  "description": "Documentation schema for integration scenario skeleton manifests. This schema describes the scenario asset contract; it does not define policy or schema authority. It explicitly documents Class 2 clarification/transition fields introduced by policy_table_v1_2_0_FROZEN.json and the dedicated safe_deferral/clarification/interaction evidence topic.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "scenario_id",
    "title",
    "description",
    "category",
    "mode",
    "input_plane",
    "preconditions",
    "steps",
    "expected_outcomes",
    "notes"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^SCN_[A-Z0-9_]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "baseline",
        "class0_emergency",
        "class1_baseline",
        "class2_insufficient_context",
        "class2_transition",
        "class2_timeout",
        "class2_caregiver_confirmation",
        "fault_stale",
        "fault_conflict",
        "fault_missing_state"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "deterministic",
        "randomized_stress"
      ]
    },
    "input_plane": {
      "type": "object",
      "required": [
        "protocol",
        "ingress_topic",
        "audit_topic"
      ],
      "additionalProperties": true,
      "properties": {
        "protocol": {
          "type": "string",
          "enum": [
            "mqtt"
          ]
        },
        "ingress_topic": {
          "type": "string",
          "minLength": 1
        },
        "normalized_policy_input_topic": {
          "type": "string",
          "minLength": 1
        },
        "clarification_interaction_topic": {
          "type": "string",
          "const": "safe_deferral/clarification/interaction"
        },
        "bridge_mode": {
          "type": "string",
          "minLength": 1
        },
        "audit_topic": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "properties": {
        "requires_class2_clarification_manager": {
          "type": "boolean"
        },
        "requires_user_feedback_output": {
          "type": "boolean"
        },
        "requires_bounded_selection_input": {
          "type": "boolean"
        },
        "requires_mqtt_registry_alignment": {
          "type": "boolean"
        },
        "requires_policy_schema_alignment": {
          "type": "boolean"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "description"
        ],
        "additionalProperties": true,
        "properties": {
          "step_id": {
            "type": [
              "integer",
              "string"
            ]
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "payload_fixture": {
            "type": "string",
            "minLength": 1
          },
          "expected_fixture": {
            "type": "string",
            "minLength": 1
          },
          "candidate_choices": {
            "$ref": "#/$defs/candidate_choices"
          }
        }
      }
    },
    "clarification_interaction": {
      "type": "object",
      "additionalProperties": true,
      "description": "Class 2 clarification/transition metadata. This is scenario metadata and must not be interpreted as pure context, validator output, or actuator command.",
      "properties": {
        "class2_role": {
          "type": "string",
          "enum": [
            "clarification_transition_state"
          ]
        },
        "clarification_topic": {
          "type": "string",
          "const": "safe_deferral/clarification/interaction"
        },
        "clarification_schema_ref": {
          "type": "string",
          "const": "common/schemas/clarification_interaction_schema_v1_0_0_FROZEN.json"
        },
        "example_payload_ref": {
          "type": "string",
          "const": "common/payloads/examples/clarification_interaction_two_options_pending.json"
        },
        "candidate_generation_actor": {
          "type": "string",
          "minLength": 1
        },
        "candidate_generation_boundary": {
          "type": "string",
          "minLength": 1
        },
        "presentation_channels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selection_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmation_required_before_transition": {
          "type": "boolean",
          "const": true
        },
        "timeout_behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "class2_clarification_expectation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Scenario-level expectation block for Class 2 clarification/transition tests. This block describes evidence and verification expectations only, not authorization.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "clarification_topic": {
          "type": "string",
          "const": "safe_deferral/clarification/interaction"
        },
        "clarification_schema_ref": {
          "type": "string",
          "const": "common/schemas/clarification_interaction_schema_v1_0_0_FROZEN.json"
        },
        "example_payload_ref": {
          "type": "string",
          "const": "common/payloads/examples/clarification_interaction_two_options_pending.json"
        },
        "expected_transition_target": {
          "type": "string"
        },
        "requires_policy_router_reentry": {
          "type": "boolean",
          "const": true
        },
        "requires_validator_when_class1": {
          "type": "boolean",
          "const": true
        },
        "timeout_must_not_infer_intent": {
          "type": "boolean",
          "const": true
        },
        "clarification_payload_is_not_authorization": {
          "type": "boolean",
          "const": true
        },
        "forbidden_interpretations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "validator_approval",
              "actuation_command",
              "emergency_trigger_authority",
              "doorlock_authorization"
            ]
          }
        }
      }
    },
    "transition_outcomes": {
      "type": "array",
      "description": "Allowed outcome families after Class 2 clarification. These outcomes describe scenario expectations, not direct actuation authority.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "transition_target",
          "condition"
        ],
        "properties": {
          "transition_target": {
            "type": "string",
            "enum": [
              "CLASS_1",
              "CLASS_0",
              "SAFE_DEFERRAL",
              "CAREGIVER_CONFIRMATION",
              "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
            ]
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "example_confirmation": {
            "type": "string"
          },
          "allowed_next_path": {
            "type": "string"
          }
        }
      }
    },
    "expected_outcomes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "route_class": {
          "type": "string"
        },
        "routing_target": {
          "type": "string"
        },
        "class2_role": {
          "type": "string",
          "enum": [
            "clarification_transition_state"
          ]
        },
        "allowed_safe_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "llm_invocation_allowed": {
          "type": "boolean"
        },
        "llm_decision_invocation_allowed": {
          "type": "boolean"
        },
        "llm_guidance_generation_allowed": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "candidate_generation_allowed": {
          "type": "boolean"
        },
        "candidate_generation_authorizes_actuation": {
          "type": "boolean"
        },
        "confirmation_required_before_transition": {
          "type": "boolean"
        },
        "allowed_transition_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CLASS_1",
              "CLASS_0",
              "SAFE_DEFERRAL",
              "CAREGIVER_CONFIRMATION",
              "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
            ]
          }
        },
        "unsafe_autonomous_actuation_allowed": {
          "type": "boolean"
        },
        "doorlock_autonomous_execution_allowed": {
          "type": "boolean"
        },
        "allowed_action_catalog_ref": {
          "type": "string"
        },
        "canonical_emergency_family": {
          "type": "string",
          "pattern": "^E00[1-5]$"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "candidate_choices": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "candidate_id",
          "candidate_transition_target"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "user_prompt": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "candidate_transition_target": {
            "type": "string",
            "enum": [
              "CLASS_1",
              "CLASS_0",
              "SAFE_DEFERRAL",
              "CAREGIVER_CONFIRMATION",
              "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
            ]
          },
          "requires_user_or_caregiver_confirmation": {
            "type": "boolean"
          },
          "requires_confirmation": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
