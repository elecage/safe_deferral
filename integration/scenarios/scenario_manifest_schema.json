{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/elecage/safe_deferral/integration/scenarios/scenario_manifest_schema.json",
  "title": "safe_deferral scenario manifest schema",
  "description": "Documentation schema for integration scenario skeleton manifests. This schema describes the scenario asset contract; it does not define policy or schema authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "scenario_id",
    "title",
    "description",
    "category",
    "mode",
    "input_plane",
    "preconditions",
    "steps",
    "expected_outcomes",
    "notes"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^SCN_[A-Z0-9_]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "baseline",
        "class0_emergency",
        "class1_baseline",
        "class2_insufficient_context",
        "fault_stale",
        "fault_conflict",
        "fault_missing_state"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "deterministic",
        "randomized_stress"
      ]
    },
    "input_plane": {
      "type": "object",
      "required": [
        "protocol",
        "ingress_topic",
        "audit_topic"
      ],
      "additionalProperties": true,
      "properties": {
        "protocol": {
          "type": "string",
          "enum": [
            "mqtt"
          ]
        },
        "ingress_topic": {
          "type": "string",
          "minLength": 1
        },
        "normalized_policy_input_topic": {
          "type": "string",
          "minLength": 1
        },
        "bridge_mode": {
          "type": "string",
          "minLength": 1
        },
        "audit_topic": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "description"
        ],
        "additionalProperties": true,
        "properties": {
          "step_id": {
            "type": [
              "integer",
              "string"
            ]
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "payload_fixture": {
            "type": "string",
            "minLength": 1
          },
          "expected_fixture": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected_outcomes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "route_class": {
          "type": "string"
        },
        "routing_target": {
          "type": "string"
        },
        "allowed_safe_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "llm_invocation_allowed": {
          "type": "boolean"
        },
        "llm_decision_invocation_allowed": {
          "type": "boolean"
        },
        "llm_guidance_generation_allowed": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "unsafe_autonomous_actuation_allowed": {
          "type": "boolean"
        },
        "doorlock_autonomous_execution_allowed": {
          "type": "boolean"
        },
        "allowed_action_catalog_ref": {
          "type": "string"
        },
        "canonical_emergency_family": {
          "type": "string",
          "pattern": "^E00[1-5]$"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
