{
  "scenario_id": "SCN_CLASS2_TIMEOUT_NO_RESPONSE_SAFE_DEFERRAL",
  "title": "Class 2 timeout or no-response safe deferral scenario",
  "description": "Deterministic scenario skeleton for a Class 2 clarification path where candidate presentation receives timeout or no response. The system must not infer user intent and must route to Safe Deferral or Caregiver Confirmation rather than autonomous actuation.",
  "category": "class2_timeout",
  "mode": "deterministic",
  "input_plane": {
    "protocol": "mqtt",
    "ingress_topic": "safe_deferral/context/input",
    "clarification_interaction_topic": "safe_deferral/clarification/interaction",
    "audit_topic": "safe_deferral/audit/log"
  },
  "preconditions": {
    "requires_mac_mini_runtime": true,
    "requires_rpi_evaluation_runtime": true,
    "requires_synced_phase0_assets": true,
    "requires_time_sync_healthy": true,
    "requires_mqtt_registry_alignment": true,
    "requires_policy_schema_alignment": true,
    "requires_class2_clarification_manager": true,
    "requires_user_feedback_output": true,
    "requires_bounded_selection_input": true
  },
  "steps": [
    {
      "step_id": 1,
      "action": "publish_ambiguous_context_payload",
      "description": "Publish an ambiguous context payload that requires Class 2 clarification.",
      "payload_fixture": "integration/tests/data/sample_policy_router_input_class2_insufficient_context.json"
    },
    {
      "step_id": 2,
      "action": "publish_clarification_interaction_evidence",
      "description": "Publish bounded candidate choices to safe_deferral/clarification/interaction. This payload is evidence only and does not authorize actuation.",
      "payload_fixture": "common/payloads/examples/clarification_interaction_two_options_pending.json"
    },
    {
      "step_id": 3,
      "action": "present_candidate_choices",
      "description": "Present bounded candidate choices through accessible feedback output."
    },
    {
      "step_id": 4,
      "action": "record_timeout_or_no_response",
      "description": "Record timeout or no-response. The system must not infer which candidate the user intended."
    },
    {
      "step_id": 5,
      "action": "route_to_safe_deferral_or_caregiver_confirmation",
      "description": "Route to Safe Deferral or Caregiver Confirmation. No Class 1 or Class 0 transition may be inferred from timeout alone."
    },
    {
      "step_id": 6,
      "action": "observe_audit_stream",
      "description": "Observe audit evidence for candidate presentation, timeout/no-response, and final safe deferral or caregiver-confirmation outcome."
    }
  ],
  "clarification_interaction": {
    "class2_role": "clarification_transition_state",
    "clarification_topic": "safe_deferral/clarification/interaction",
    "clarification_schema_ref": "common/schemas/clarification_interaction_schema_v1_0_0_FROZEN.json",
    "example_payload_ref": "common/payloads/examples/clarification_interaction_two_options_pending.json",
    "candidate_generation_actor": "LLM_GUIDANCE_LAYER_OR_INPUT_CONTEXT_MAPPER",
    "candidate_generation_boundary": "candidate_generation_only_no_final_decision_no_actuation_authority",
    "presentation_channels": [
      "TTS_OR_VOICE_OUTPUT",
      "DISPLAY_OUTPUT",
      "ACCESSIBLE_FEEDBACK_OUTPUT"
    ],
    "selection_inputs": [
      "TIMEOUT_OR_NO_RESPONSE"
    ],
    "confirmation_required_before_transition": true,
    "timeout_behavior": "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
  },
  "class2_clarification_expectation": {
    "enabled": true,
    "clarification_topic": "safe_deferral/clarification/interaction",
    "clarification_schema_ref": "common/schemas/clarification_interaction_schema_v1_0_0_FROZEN.json",
    "example_payload_ref": "common/payloads/examples/clarification_interaction_two_options_pending.json",
    "expected_transition_target": "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION",
    "requires_policy_router_reentry": true,
    "requires_validator_when_class1": true,
    "timeout_must_not_infer_intent": true,
    "clarification_payload_is_not_authorization": true,
    "forbidden_interpretations": [
      "validator_approval",
      "actuation_command",
      "emergency_trigger_authority",
      "doorlock_authorization"
    ]
  },
  "transition_outcomes": [
    {
      "transition_target": "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION",
      "condition": "Candidate presentation times out or receives no response.",
      "allowed_next_path": "safe_deferral_or_caregiver_confirmation_path"
    }
  ],
  "expected_outcomes": {
    "route_class": "CLASS_2",
    "class2_role": "clarification_transition_state",
    "candidate_generation_allowed": true,
    "candidate_generation_authorizes_actuation": false,
    "confirmation_required_before_transition": true,
    "allowed_transition_targets": [
      "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
    ],
    "timeout_must_not_infer_intent": true,
    "unsafe_autonomous_actuation_allowed": false,
    "doorlock_autonomous_execution_allowed": false
  },
  "notes": [
    "Timeout or no-response is not a user selection.",
    "The system must not infer intent from silence or lack of response.",
    "No Class 1 actuation or Class 0 emergency transition may be inferred from timeout alone.",
    "Timeout/no-response must be audit-visible."
  ]
}
