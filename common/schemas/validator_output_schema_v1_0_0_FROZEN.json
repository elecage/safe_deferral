{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deterministic Validator Output",
  "description": "Strict internal payload generated by the Deterministic Validator. Dictates the exact deterministic routing to the Actuator Dispatcher, iCR Handler, or Class 2 Escalation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "validation_status": {
      "type": "string",
      "enum": [
        "approved",
        "safe_deferral",
        "rejected_escalation"
      ],
      "description": "The final deterministic evaluation result of the LLM's candidate action."
    },
    "routing_target": {
      "type": "string",
      "enum": [
        "actuator_dispatcher",
        "icr_handler",
        "class_2_escalation"
      ],
      "description": "The specific system module this payload is routed to next."
    },
    "executable_payload": {
      "type": "object",
      "description": "Populated ONLY if validation_status is 'approved'. Structurally blocked otherwise.",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "light_on",
            "light_off"
          ]
        },
        "target_device": {
          "type": "string",
          "enum": [
            "living_room_light",
            "bedroom_light"
          ]
        },
        "requires_ack": {
          "type": "boolean",
          "description": "Policy-derived closed-loop control flag. Dispatcher must wait for physical state ACK before confirming success."
        }
      },
      "required": [
        "action",
        "target_device",
        "requires_ack"
      ]
    },
    "exception_trigger_id": {
      "type": "string",
      "enum": [
        "none",
        "C201",
        "C202",
        "C203",
        "C204",
        "C205"
      ],
      "description": "Matches the policy table trigger ID if escalated. Must be 'none' for approved or safe_deferral."
    },
    "deferral_reason": {
      "type": "string",
      "enum": [
        "ambiguous_target",
        "insufficient_context",
        "policy_restriction",
        "unresolved_multi_candidate"
      ],
      "description": "Reason for deferral passed to iCR handler to generate clarification prompts."
    }
  },
  "required": [
    "validation_status",
    "routing_target",
    "exception_trigger_id"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "approved"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "actuator_dispatcher"
          },
          "exception_trigger_id": {
            "const": "none"
          },
          "deferral_reason": false
        },
        "required": [
          "executable_payload"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "safe_deferral"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "icr_handler"
          },
          "exception_trigger_id": {
            "const": "none"
          },
          "executable_payload": false
        },
        "required": [
          "deferral_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "rejected_escalation"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "class_2_escalation"
          },
          "exception_trigger_id": {
            "enum": [
              "C201",
              "C202",
              "C203",
              "C204",
              "C205"
            ]
          },
          "executable_payload": false,
          "deferral_reason": false
        }
      }
    }
  ]
}