{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "clarification_interaction_schema_v1_0_0",
  "description": "Schema for Class 2 clarification interaction artifacts: bounded candidate choices, presentation channel, user/caregiver selection, timeout/no-response result, and transition target. This schema does not define pure context input, validator approval, actuation command, doorlock authorization, or emergency trigger authority.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "clarification_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Unique identifier for this clarification interaction."
    },
    "audit_correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Correlation ID linking this clarification interaction to audit logs and upstream events."
    },
    "source_scenario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Optional scenario identifier when this payload is used in integration fixtures or tests."
    },
    "source_layer": {
      "type": "string",
      "enum": [
        "policy_router",
        "validator",
        "context_integrity_safe_deferral_handler",
        "class2_clarification_manager",
        "input_context_mapper",
        "llm_guidance_layer",
        "system"
      ],
      "description": "Layer that created or updated this clarification interaction artifact."
    },
    "unresolved_reason": {
      "type": "string",
      "enum": [
        "insufficient_context",
        "ambiguous_candidates",
        "missing_policy_input",
        "unresolved_context_conflict",
        "sensor_staleness_detected",
        "actuation_ack_timeout",
        "missing_state",
        "caregiver_required_sensitive_path",
        "timeout_or_no_response",
        "other"
      ],
      "description": "Machine-readable reason for entering or remaining in Class 2 clarification."
    },
    "candidate_choices": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "description": "Bounded choices that may be presented to the user/caregiver for confirmation. Candidate choices are guidance only and do not authorize actuation.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "prompt",
          "candidate_transition_target",
          "requires_confirmation"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "prompt": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "candidate_transition_target": {
            "type": "string",
            "enum": [
              "CLASS_1",
              "CLASS_0",
              "SAFE_DEFERRAL",
              "CAREGIVER_CONFIRMATION",
              "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION"
            ]
          },
          "requires_confirmation": {
            "type": "boolean",
            "const": true
          },
          "allowed_next_path": {
            "type": "string",
            "maxLength": 160
          },
          "risk_note": {
            "type": "string",
            "maxLength": 300
          }
        }
      }
    },
    "presentation_channel": {
      "type": "string",
      "enum": [
        "tts",
        "display",
        "accessible_feedback",
        "caregiver_notification",
        "local_dashboard",
        "other"
      ],
      "description": "Channel used to present candidate choices or clarification prompt."
    },
    "selection_result": {
      "type": "object",
      "additionalProperties": false,
      "description": "Result of user/caregiver selection. Omit when no selection has been collected yet.",
      "required": [
        "selection_source",
        "confirmed"
      ],
      "properties": {
        "selected_candidate_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "selection_source": {
          "type": "string",
          "enum": [
            "bounded_input_node",
            "voice_input",
            "caregiver_confirmation",
            "deterministic_emergency_evidence",
            "timeout_or_no_response",
            "none"
          ]
        },
        "confirmed": {
          "type": "boolean"
        },
        "selection_timestamp_ms": {
          "type": "integer"
        }
      }
    },
    "transition_target": {
      "type": "string",
      "enum": [
        "CLASS_1",
        "CLASS_0",
        "SAFE_DEFERRAL",
        "CAREGIVER_CONFIRMATION",
        "SAFE_DEFERRAL_OR_CAREGIVER_CONFIRMATION",
        "PENDING"
      ],
      "description": "Resulting transition target after confirmation, deterministic evidence, timeout, or pending state."
    },
    "timeout_result": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending",
        "timeout_no_response",
        "timeout_ambiguous_response",
        "safe_deferral_or_caregiver_confirmation"
      ]
    },
    "llm_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_generation_only",
        "final_decision_allowed",
        "actuation_authority_allowed",
        "emergency_trigger_authority_allowed"
      ],
      "properties": {
        "candidate_generation_only": {
          "type": "boolean",
          "const": true
        },
        "final_decision_allowed": {
          "type": "boolean",
          "const": false
        },
        "actuation_authority_allowed": {
          "type": "boolean",
          "const": false
        },
        "emergency_trigger_authority_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "timestamp_ms": {
      "type": "integer",
      "description": "Creation or update timestamp in epoch milliseconds."
    }
  },
  "required": [
    "clarification_id",
    "unresolved_reason",
    "candidate_choices",
    "transition_target",
    "llm_boundary"
  ]
}
