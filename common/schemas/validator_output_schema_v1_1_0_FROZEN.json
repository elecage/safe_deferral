{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "validator_output_schema_v1_1_0",
  "description": "Strict internal payload generated by the Deterministic Validator. Dictates deterministic routing to the actuator dispatcher, context-integrity safe deferral handler, or Class 2 escalation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "validation_status": {
      "type": "string",
      "enum": [
        "approved",
        "safe_deferral",
        "rejected_escalation"
      ],
      "description": "Final deterministic evaluation result of the candidate action set."
    },
    "routing_target": {
      "type": "string",
      "enum": [
        "actuator_dispatcher",
        "context_integrity_safe_deferral_handler",
        "class_2_escalation"
      ],
      "description": "The exact next system module selected by deterministic validation."
    },
    "executable_payload": {
      "type": "object",
      "description": "Present only when validation_status is approved.",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "light_on",
            "light_off"
          ]
        },
        "target_device": {
          "type": "string",
          "enum": [
            "living_room_light",
            "bedroom_light"
          ]
        },
        "requires_ack": {
          "type": "boolean",
          "description": "Policy-derived closed-loop control flag. Dispatcher must wait for device state ACK before confirming success."
        }
      },
      "required": [
        "action",
        "target_device",
        "requires_ack"
      ]
    },
    "exception_trigger_id": {
      "type": "string",
      "enum": [
        "none",
        "C201",
        "C202",
        "C203",
        "C204",
        "C205",
        "C206"
      ],
      "description": "Policy trigger ID used for Class 2 escalation. Must be 'none' for approved or safe_deferral."
    },
    "deferral_reason": {
      "type": "string",
      "enum": [
        "ambiguous_target",
        "insufficient_context",
        "policy_restriction",
        "unresolved_multi_candidate"
      ],
      "description": "Reason for safe deferral passed to the context-integrity safe deferral handler."
    }
  },
  "required": [
    "validation_status",
    "routing_target",
    "exception_trigger_id"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "approved"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "actuator_dispatcher"
          },
          "exception_trigger_id": {
            "const": "none"
          },
          "deferral_reason": false
        },
        "required": [
          "executable_payload"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "safe_deferral"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "context_integrity_safe_deferral_handler"
          },
          "exception_trigger_id": {
            "const": "none"
          },
          "executable_payload": false
        },
        "required": [
          "deferral_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "validation_status": {
            "const": "rejected_escalation"
          }
        }
      },
      "then": {
        "properties": {
          "routing_target": {
            "const": "class_2_escalation"
          },
          "exception_trigger_id": {
            "enum": [
              "C201",
              "C202",
              "C203",
              "C204",
              "C205",
              "C206"
            ]
          },
          "executable_payload": false,
          "deferral_reason": false
        }
      }
    }
  ]
}
