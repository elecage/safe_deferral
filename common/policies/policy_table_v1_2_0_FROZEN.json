{
  "version": "1.2.0",
  "description": "Deterministic Routing Policy and Safety Constraints for Edge Smart Home",
  "global_constraints": {
    "freshness_threshold_ms": 3000,
    "default_context_integrity_safe_deferral_timeout_ms": 15000,
    "actuation_ack_timeout_ms": 5000,
    "max_context_integrity_safe_deferral_attempts": 2
  },
  "compatibility_notes": {
    "deprecated_terms": [
      "icr",
      "icr_handler",
      "iCR-based safe deferral stage"
    ],
    "canonical_term": "context-integrity-based safe deferral stage",
    "notes": [
      "Implementations should prefer context-integrity-based safe deferral terminology.",
      "If temporary backward compatibility is needed, handle legacy aliases at the adapter layer rather than preserving them as the canonical field names."
    ]
  },
  "routing_policies": {
    "class_0_emergency": {
      "description": "Life-critical emergencies requiring immediate deterministic override.",
      "triggers": [
        {
          "id": "E001",
          "source_type": "sensor",
          "severity": "high",
          "type": "threshold_crossing",
          "minimal_triggering_predicate": {
            "sensor": "temperature",
            "operator": ">=",
            "value": 50.0
          },
          "local_action_immediate": true,
          "external_dispatch_grace_period_ms": 5000
        },
        {
          "id": "E002",
          "source_type": "button",
          "severity": "high",
          "type": "pattern_event",
          "minimal_triggering_predicate": {
            "event": "triple_hit"
          },
          "local_action_immediate": true,
          "external_dispatch_grace_period_ms": 10000
        },
        {
          "id": "E003",
          "source_type": "sensor",
          "severity": "high",
          "type": "state_trigger",
          "minimal_triggering_predicate": {
            "sensor": "smoke_detected",
            "operator": "==",
            "value": true
          },
          "local_action_immediate": true,
          "external_dispatch_grace_period_ms": 5000
        },
        {
          "id": "E004",
          "source_type": "sensor",
          "severity": "high",
          "type": "state_trigger",
          "minimal_triggering_predicate": {
            "sensor": "gas_detected",
            "operator": "==",
            "value": true
          },
          "local_action_immediate": true,
          "external_dispatch_grace_period_ms": 5000
        },
        {
          "id": "E005",
          "source_type": "sensor",
          "severity": "high",
          "type": "event_trigger",
          "minimal_triggering_predicate": {
            "event_type": "sensor",
            "event_code": "fall_detected"
          },
          "local_action_immediate": false,
          "external_dispatch_grace_period_ms": 5000,
          "schema_dependency_note": "Requires aligned trigger_event.event_code support for fall_detected in context_schema_v1_0_0_FROZEN.json"
        }
      ],
      "button_event_interpretation": {
        "emergency_pattern": "triple_hit",
        "ambiguous_emergency_like_patterns": [
          "double_click",
          "long_press"
        ],
        "action_on_ambiguity": "downgrade_to_class_2"
      },
      "actions": [
        {
          "action": "activate_siren",
          "execution_order": 1,
          "action_scope": "local_immediate"
        },
        {
          "action": "turn_on_all_lights",
          "execution_order": 2,
          "action_scope": "local_immediate"
        },
        {
          "action": "dispatch_emergency_alert",
          "execution_order": 3,
          "action_scope": "external_dispatch"
        }
      ]
    },
    "class_1_low_risk": {
      "description": "Bounded low-risk assistance handled by local LLM and Deterministic Validator.",
      "allowed_actions_taxonomy": [
        {
          "action": "light_on",
          "risk_level": "low",
          "requires_ack": true,
          "allowed_targets": [
            "living_room_light",
            "bedroom_light"
          ]
        },
        {
          "action": "light_off",
          "risk_level": "low",
          "requires_ack": true,
          "allowed_targets": [
            "living_room_light",
            "bedroom_light"
          ]
        }
      ],
      "constraints": {
        "require_single_admissible_action": true,
        "fallback_on_conflict": "safe_deferral",
        "fallback_on_missing_schema": "safe_deferral",
        "fallback_on_staleness": "escalate_to_class_2"
      },
      "clarification": {
        "mode": "button_based_context_integrity_safe_deferral",
        "max_candidate_options": 3,
        "timeout_ms": 15000,
        "max_attempts": 2,
        "action_on_success": "execute_validated_action",
        "action_on_timeout": "escalate_to_class_2"
      }
    },
    "class_2_escalation": {
      "description": "Caregiver escalation for unresolved ambiguity, sensor staleness, missing critical context, or actuation failure.",
      "triggers": [
        {
          "id": "C201",
          "event": "context_integrity_safe_deferral_timeout",
          "source_layer": "context_integrity_safe_deferral_handler",
          "requires_notification": true
        },
        {
          "id": "C202",
          "event": "missing_policy_input",
          "source_layer": "policy_router",
          "requires_notification": true
        },
        {
          "id": "C203",
          "event": "unresolved_context_conflict",
          "source_layer": "validator",
          "requires_notification": true
        },
        {
          "id": "C204",
          "event": "sensor_staleness_detected",
          "source_layer": "policy_router",
          "requires_notification": true
        },
        {
          "id": "C205",
          "event": "actuation_ack_timeout",
          "source_layer": "validator",
          "requires_notification": true
        },
        {
          "id": "C206",
          "event": "ambiguous_emergency_like_button_pattern",
          "source_layer": "policy_router",
          "requires_notification": true
        }
      ],
      "payload_requirements": [
        "event_id",
        "trigger_id",
        "event_summary",
        "context_summary",
        "unresolved_reason",
        "source_layer",
        "manual_confirmation_path"
      ],
      "optional_payload_fields": [
        "candidate_options",
        "related_device_state",
        "observed_timestamp_ms"
      ]
    }
  },
  "implementation_notes": {
    "authoritative_low_risk_action_catalog": "low_risk_actions_v1_0_0_FROZEN.json",
    "note": "The routing policy may retain a summarized allowed_actions_taxonomy for local readability, but the dedicated low-risk action catalog should remain the authoritative action list."
  }
}
