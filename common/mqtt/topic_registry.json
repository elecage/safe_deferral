{
  "registry_version": "1.1.0",
  "status": "DRAFT",
  "supersedes": "common/history/mqtt/topic_registry.json",
  "description": "MQTT topic registry for safe_deferral with machine-readable publisher/subscriber role metadata. Topic names are implementation-facing draft contracts and must be reviewed before freezing.",
  "authority_note": "This registry defines communication contracts, publisher/subscriber roles, and topic metadata. It does not define policy authority, schema authority, validator authority, or actuation authority. Policies and schemas under common/policies and common/schemas remain authoritative.",
  "role_metadata_note": "Version 1.1.0 adds publisher/subscriber role classification so governance tooling can distinguish field-side operational publishers, Mac mini runtime services, controlled experiment publishers, optional observers, and dashboard/governance visibility roles.",
  "global_rules": [
    "All schema-governed payloads must validate against the referenced schema.",
    "All referenced example_payload files should exist under common/payloads/examples/ when specified.",
    "Topics are communication contracts, not execution authority.",
    "Publisher/subscriber role metadata is used for governance and verification, not policy authority.",
    "Dashboard topics are visibility artifacts and must not become policy authority.",
    "Audit topics are evidence artifacts and must not become policy authority.",
    "RPi simulation and fault topics are allowed only in controlled experiment or simulation mode.",
    "doorbell_detected is visitor-response context only and must not authorize emergency handling or autonomous doorlock control.",
    "Doorlock-sensitive outcomes must route through Class 2 escalation or separately governed manual confirmation with ACK and audit.",
    "LLM candidate/guidance topics never authorize actuation.",
    "Class 2 clarification interaction payloads are evidence/transition records and must not be treated as validator approval, actuation commands, emergency trigger authority, or doorlock authorization.",
    "Governance dashboard UI must not publish operational control topics, expose unrestricted actuator consoles, or expose direct doorlock command controls.",
    "Governance backend must not directly modify canonical policies/schemas, publish actuator or doorlock commands, spoof caregiver approval, override the Policy Router or Deterministic Validator, or convert draft/proposed changes into live authority without review.",
    "FAULT_CONTRACT_DRIFT_01 is a governance/verification fault profile and must not be treated as an operational control path."
  ],
  "role_classes": {
    "field_operational_publisher": "Physical or embedded field-side node that publishes operational input/evidence.",
    "mac_mini_runtime_publisher": "Mac mini runtime service that publishes operational runtime outputs or internal integration events.",
    "mac_mini_controlled_bridge_publisher": "Mac mini bridge publisher used only when explicitly configured for normalized controlled re-publication.",
    "controlled_experiment_publisher": "RPi or test harness publisher allowed only in controlled simulation/evaluation mode.",
    "runtime_subscriber": "Operational runtime service that consumes the topic.",
    "actuator_subscriber": "Physical or governed actuator-side subscriber.",
    "observer_subscriber": "Audit, dashboard, telemetry, or governance observer that must not create control authority.",
    "dashboard_visibility_subscriber": "Dashboard-facing subscriber used for visibility only.",
    "analysis_subscriber": "Offline analysis or paper-result consumer."
  },
