      "retain": false,
      "authority_level": "validator_decision",
      "allowed_in_operational_runtime": true,
      "allowed_in_experiment_runtime": true,
      "audit_recommended": true,
      "notes": [
        "Approved executable payload must remain within frozen low-risk catalog.",
        "Doorlock executable payload is not allowed under current baseline."
      ]
    },
    {
