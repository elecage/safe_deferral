      "qos": 1,
      "retain": false,
      "authority_level": "model_candidate_not_authority",
      "allowed_in_operational_runtime": true,
      "allowed_in_experiment_runtime": true,
      "audit_recommended": true,
      "notes": [
        "LLM candidate action is not execution authority.",
        "door_unlock must not appear as current Class 1 candidate action."
      ]
    },
    {
      "topic": "safe_deferral/validator/output",
