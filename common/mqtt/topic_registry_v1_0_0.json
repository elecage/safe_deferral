{
  "registry_version": "1.0.0",
  "status": "DRAFT",
  "description": "Initial MQTT topic registry for safe_deferral. Topic names are implementation-facing draft contracts and must be reviewed before freezing.",
  "authority_note": "This registry defines communication contracts, not policy authority. Policies and schemas under common/policies and common/schemas remain authoritative.",
  "global_rules": [
    "All schema-governed payloads must validate against the referenced schema.",
    "Dashboard topics are visibility artifacts and must not become policy authority.",
    "Audit topics are evidence artifacts and must not become policy authority.",
    "RPi simulation and fault topics are allowed only in controlled experiment or simulation mode.",
    "doorbell_detected is visitor-response context only and must not authorize autonomous doorlock control.",
    "Doorlock-sensitive outcomes must route through Class 2 escalation or separately governed manual confirmation with ACK and audit."
  ],
  "topics": [
    {
      "topic": "safe_deferral/context/input",
      "description": "Normalized policy-router input wrapper carrying pure context payload and routing metadata.",
      "publishers": [
        "mac_mini.context_aggregator",
        "rpi.simulation_runtime_controlled_mode"
      ],
      "subscribers": [
        "mac_mini.policy_router",
        "mac_mini.audit_logging_service_observer_optional"
      ],
      "payload_family": "policy_router_input",
      "schema": "common/schemas/policy_router_input_schema_v1_1_1_FROZEN.json",
      "example_payload": "common/payloads/examples/policy_router_input_non_visitor.json",
      "qos": 1,
      "retain": false,
      "authority_level": "operational_input",
      "allowed_in_operational_runtime": true,
      "allowed_in_experiment_runtime": true,
      "audit_recommended": true,
      "notes": [
        "Payload must include pure_context_payload.environmental_context.doorbell_detected.",
        "RPi publisher is allowed only in controlled experiment/simulation mode."
      ]
    },
    {
      "topic": "safe_deferral/emergency/event",
      "description": "Policy-declared emergency event input aligned with E001-E005.",
      "publishers": [
        "esp32.emergency_node",
        "rpi.virtual_emergency_sensor_controlled_mode"
      ],
      "subscribers": [
        "mac_mini.policy_router",
        "mac_mini.audit_logging_service_observer_optional"
      ],
      "payload_family": "policy_router_input_or_emergency_context",
      "schema": "common/schemas/policy_router_input_schema_v1_1_1_FROZEN.json",
      "example_payload": "common/payloads/examples/policy_router_input_emergency_temperature.json",
      "qos": 1,
      "retain": false,
      "authority_level": "operational_input_emergency",
      "allowed_in_operational_runtime": true,
      "allowed_in_experiment_runtime": true,
      "audit_recommended": true,
      "notes": [
        "Emergency semantics must remain aligned with E001-E005.",
        "doorbell_detected is not an emergency trigger."
      ]
    },
    {
      "topic": "safe_deferral/llm/candidate_action",
